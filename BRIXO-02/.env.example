# ── Base de Datos ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=brixo
DB_USER=root
DB_PASSWORD=tu_password
DB_SSL=false

# ── LLM (Cotizador IA) ───────────────────────────────────────────────────────
# Proveedor recomendado: groq (gratuito)
LLM_PROVIDER=groq
LLM_API_KEY=gsk_tu_clave_aqui
LLM_MODEL=llama-3.3-70b-versatile

# Alternativa Anthropic Claude:
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-tu_clave
# LLM_MODEL=claude-sonnet-4-20250514

# Alternativa OpenAI:
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-tu_clave
# LLM_MODEL=gpt-4o-mini

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=8080
